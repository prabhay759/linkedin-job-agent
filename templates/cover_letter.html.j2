<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11pt; color: #1a1a1a; background: #fff; }
  .page { padding: 25mm 22mm; max-width: 210mm; }

  .sender { margin-bottom: 24px; }
  .sender .name { font-size: 13pt; font-weight: 700; color: #1a1a1a; }
  .sender .contact { font-size: 9.5pt; color: #555; margin-top: 4px; line-height: 1.6; }

  .date { font-size: 10pt; color: #555; margin-bottom: 20px; }

  .recipient { margin-bottom: 20px; }
  .recipient .company { font-weight: 700; font-size: 11pt; }
  .recipient .role { font-size: 10pt; color: #444; margin-top: 2px; }

  .salutation { font-size: 11pt; margin-bottom: 16px; font-weight: 600; }

  .body p {
    font-size: 10.5pt; line-height: 1.65; color: #1a1a1a;
    margin-bottom: 14px; text-align: justify;
  }

  .closing { margin-top: 28px; }
  .closing .sign { font-size: 11pt; font-weight: 600; margin-bottom: 4px; }
  .closing .name-final { font-size: 11pt; color: #1a1a1a; }

  .header-bar {
    width: 50px; height: 3px; background: #1a56db;
    margin-bottom: 20px;
  }

  @media print {
    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .page { padding: 0; }
  }
</style>
</head>
<body>
<div class="page">

  <div class="header-bar"></div>

  <div class="sender">
    <div class="name">{{ name }}</div>
    <div class="contact">
      {% if email %}{{ email }}{% endif %}
      {% if phone %} · {{ phone }}{% endif %}
      {% if location %} · {{ location }}{% endif %}
    </div>
  </div>

  <div class="date">{{ date }}</div>

  <div class="recipient">
    <div class="company">{{ company }}</div>
    <div class="role">Re: {{ job_title }}</div>
  </div>

  <div class="salutation">{{ salutation }}</div>

  <div class="body">
    {% for para in paragraphs %}
    <p>{{ para }}</p>
    {% endfor %}
  </div>

  <div class="closing">
    <div class="sign">{{ closing }}</div>
    <div class="name-final">{{ name }}</div>
  </div>

</div>
</body>
</html>
