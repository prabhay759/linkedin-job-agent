# ── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/yourhandle/
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=yourpassword

# ── Job Search ────────────────────────────────────────────────────────────
# Comma-separated job keywords to search for
JOB_KEYWORDS=Python Engineer,Backend Engineer,Software Engineer
# Comma-separated locations (use "Remote" for remote-only)
JOB_LOCATIONS=London,Remote

# ── OpenRouter (free LLM — auto-detects best available free model) ────────
# Get your free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Telegram ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# Your personal Telegram chat ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=123456789

# ── Your personal details (used in CV and ATS forms) ─────────────────────
YOUR_FULL_NAME=Jane Doe
YOUR_PHONE=+44 7700 900123
YOUR_EMAIL=you@example.com
YOUR_LOCATION=London, UK

# ── Tuning ────────────────────────────────────────────────────────────────
# Jobs scoring >= MIN_SCORE (1-10) will get a CV generated and confirmation sent
MIN_SCORE=7
# How long to wait for your YES/NO reply before expiring the confirmation (hours)
CONFIRMATION_TIMEOUT_HOURS=24
# Maximum new jobs to score per scan (controls LLM API cost)
MAX_JOBS_PER_SCAN=20
